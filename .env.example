# AquaScan Environment Variables
# Copy this file to .env and fill in your values

# Supabase (optional — app works without this)
SUPABASE_URL=
SUPABASE_KEY=

# App settings
APP_TITLE=AquaScan
APP_VERSION=1.0.0
DEFAULT_LAT=16.3067
DEFAULT_LON=80.4365
DEBUG_MODE=false

# Model
MODEL_PATH=models/weights/best.pt
MOCK_MODE=auto  # auto = detect based on file existence
